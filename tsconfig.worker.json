{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": ".",
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022"]
  },
  "include": [
    "src/worker/**/*",
    "src/tools/**/*",
    "src/schemas.ts",
    "src/attestation.ts",
    "src/version.ts",
    "src/generated/**/*"
  ],
  "exclude": []
}
