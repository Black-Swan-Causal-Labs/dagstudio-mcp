# agents@0.9 declares a zod@^4 peer, but this project (and the MCP SDK 1.x)
# uses zod 3. The deployed worker is built and verified against this exact
# combination; legacy-peer-deps makes fresh installs reproduce it instead of
# failing resolution. Revisit when migrating to the 2026-07-28 MCP SDK.
legacy-peer-deps=true
